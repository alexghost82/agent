rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }

    match /sources/{doc} { allow read, write: if signedIn(); }
    match /knowledge_chunks/{doc} { allow read, write: if signedIn(); }
    match /agent_skills/{doc} { allow read, write: if signedIn(); }
    match /project_decisions/{doc} { allow read, write: if signedIn(); }
    match /build_tasks/{doc} { allow read, write: if signedIn(); }
    match /approvals/{doc} { allow read, write: if signedIn(); }
    match /generated_code/{doc} { allow read, write: if signedIn(); }
    match /reviews/{doc} { allow read, write: if signedIn(); }
    match /security_reviews/{doc} { allow read, write: if signedIn(); }
    match /agent_logs/{doc} { allow read, write: if signedIn(); }
  }
}
