# Next.js frontend environment — EXAMPLE (no real secrets here).
# Copy to .env.local and fill in.

# Base URL of the Firebase Functions API (the /api prefix is stripped server-side).
NEXT_PUBLIC_API_BASE=http://127.0.0.1:5001/YOUR_PROJECT_ID/us-central1/api

# NOTE: AI provider secrets are server-only and live in functions/.env
# (see functions/.env.example: KEYS_ENC_SECRET, OPENAI_API_KEY, GEMINI_API_KEY).
# Raw API keys are NEVER exposed to the frontend.
