# Firebase Functions environment — EXAMPLE (no real secrets here).
# Copy to functions/.env and fill in. Never commit real keys.

# --- Server AI keys (used as FALLBACK when a user has not set their own) ---
# OpenAI server key. Used when aiProvider="openai" and the user has no stored key.
OPENAI_API_KEY=sk-your-openai-key
# Optional chat model override.
OPENAI_CHAT_MODEL=gpt-4.1-mini
# Optional Gemini server key. Used when aiProvider="gemini" and the user has no stored key.
GEMINI_API_KEY=AIza-your-gemini-key

# --- Encryption ---
# Master secret for AES-256-GCM encryption of users' stored API keys.
# Must be a strong, random value (recommended: 32+ bytes, e.g. `openssl rand -hex 32`).
# Required for the bring-your-own-key feature; raw user keys are never stored or returned.
KEYS_ENC_SECRET=replace-with-a-strong-random-secret

# --- Auth / seeding ---
# Seed users (created on first login if missing). Never commit real values.
# Format: "Name:password,Name2:password2"
SEED_USERS=Alex:ghost,Omer:ghost

# --- CORS ---
# Optional: comma-separated allowed CORS origins. If empty, all origins are reflected.
ALLOWED_ORIGINS=

# --- Build verification (CONTRACT v3.1 / Epic 4) ---
# Real-toolchain verification of generated builds (tsc/eslint/npm test) over the
# files in an ephemeral sandbox. Leave UNSET on the shared `api` process (it only
# runs static checks). Set to 1 ONLY on an isolated, disposable runner instance.
# BUILD_EXEC_ENABLED=1
# Hard per-process timeout for sandbox toolchain runs (ms). Default 120000.
# BUILD_EXEC_TIMEOUT_MS=120000
# Auto-fix: when verification fails, do ONE LLM repair pass with the failed-check
# logs, regenerate and re-verify, keeping the better result. Default ON (safe).
# Set to 0 to disable.
# BUILD_AUTOFIX=1
